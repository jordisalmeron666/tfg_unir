{
    "name": "devc_tfg_py:3.13-slim",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--name", "devc_tfg_bot",
        "--add-host=host.docker.internal:host-gateway",
        "--network=host"
    ],
    
    "postCreateCommand": "pip install -r requirements.txt",

    "extensions": [
        "GitHub.copilot",
        "ms-python.python",
        "Gruntfuggly.todo-tree"
    ],
}